# Copy to .env and fill in values

APP_NAME="GolfTrainer API"
ENVIRONMENT=development
DEBUG=true

# Database
# Dev: SQLite (no changes needed)
DATABASE_URL=sqlite+aiosqlite:///./golf.db
# Prod: PostgreSQL
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/golf

# JWT — change in production!
SECRET_KEY=your-super-secret-key-change-this
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# DigitalOcean Spaces
SPACES_KEY=your-spaces-access-key
SPACES_SECRET=your-spaces-secret-key
SPACES_REGION=ams3
SPACES_BUCKET=golf-trainer
SPACES_ENDPOINT=https://ams3.digitaloceanspaces.com
# Optional CDN endpoint (faster delivery)
# SPACES_CDN_ENDPOINT=https://golf-trainer.ams3.cdn.digitaloceanspaces.com

# CORS (comma-separated in prod)
# ALLOWED_ORIGINS=["https://yourdomain.com"]

# File limits (MB)
MAX_VIDEO_SIZE_MB=500
MAX_IMAGE_SIZE_MB=10
